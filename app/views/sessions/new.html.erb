<div class="min-h-[60vh] grid place-items-center w-full px-4">
  <div class="card bg-base-100 shadow-md w-full max-w-md border border-base-300">
    <div class="card-body space-y-4">
      <%= render "shared/flash" %>
      <h1 class="card-title text-2xl">Sign in</h1>

      <%= form_with url: session_url, class: "space-y-3" do |form| %>
        <div class="form-control">
          <%= form.label :email_address, class: "label label-text" %>
          <%= form.email_field :email_address, required: true, autofocus: true,
            autocomplete: "username", value: params[:email_address],
            class: "input input-bordered input-sm w-full" %>
        </div>

        <div class="form-control">
          <%= form.label :password, class: "label label-text" %>
          <%= form.password_field :password, required: true, autocomplete: "current-password",
            maxlength: 72, class: "input input-bordered input-sm w-full" %>
        </div>

        <div class="flex items-center justify-between">
          <%= form.submit "Sign in", class: "btn btn-primary" %>
          <%= link_to "Forgot password?", new_password_path, class: "link link-hover text-sm" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
