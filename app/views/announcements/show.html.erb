<% future = @announcement.published_at && @announcement.published_at > Time.current %>
<% reads_count = @announcement.announcement_reads.count %>

<div class="w-full max-w-7xl mx-auto p-4 space-y-6">
  <header class="flex items-start justify-between gap-4 flex-wrap">
    <div class="text-sm text-base-content/60">
      <%= link_to "Announcements", announcements_path, class: "link link-hover" %>
      <span class="mx-1">›</span>
      <span>#<%= @announcement.id %></span>
    </div>
    <% if authenticated? %>
      <div class="flex gap-2">
        <%= link_to "Back", announcements_path, class: "btn btn-sm btn-ghost" %>
        <%= link_to "Edit", edit_announcement_path(@announcement), class: "btn btn-sm" %>
        <%= link_to "Delete", @announcement,
              class: "btn btn-sm btn-ghost text-error",
              data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %>
      </div>
    <% end %>
  </header>

  <article class="card bg-base-100 border border-base-300 shadow-sm">
    <div class="card-body space-y-6">
      <header class="space-y-2">
        <h1 class="text-2xl font-bold leading-tight"><%= @announcement.title %></h1>
        <div class="flex flex-wrap items-center gap-2 text-xs text-base-content/60">
          <% if future %>
            <span class="badge badge-warning badge-outline">Scheduled</span>
            <span>publishes in <%= time_ago_in_words(@announcement.published_at) %></span>
          <% else %>
            <span>published <%= time_ago_in_words(@announcement.published_at) %> ago</span>
          <% end %>
          <% if @announcement.segments.empty? %>
            <span class="badge badge-success badge-outline">Broadcast</span>
          <% else %>
            <span>·</span>
            <span>targeting <%= pluralize(@announcement.segment_values.count, "value") %></span>
          <% end %>
          <% if authenticated? %>
            <span>·</span>
            <span><%= pluralize(reads_count, "read") %></span>
          <% end %>
        </div>
      </header>

      <% if @announcement.preview.present? %>
        <section>
          <h2 class="text-xs uppercase tracking-wide text-base-content/60 font-semibold mb-2">Preview</h2>
          <p class="text-base-content/80"><%= @announcement.preview %></p>
        </section>
      <% end %>

      <section>
        <h2 class="text-xs uppercase tracking-wide text-base-content/60 font-semibold mb-2">Content</h2>
        <div class="prose max-w-none">
          <%= @announcement.content %>
        </div>
      </section>

      <% if @announcement.segments.any? %>
        <section>
          <h2 class="text-xs uppercase tracking-wide text-base-content/60 font-semibold mb-3">Targeting</h2>
          <div class="space-y-2">
            <% @announcement.segments.each do |segment| %>
              <% values = @announcement.segment_values.where(segment: segment) %>
              <div class="flex flex-wrap items-center gap-2">
                <span class="font-medium text-sm min-w-24"><%= segment.identifier %></span>
                <% values.each do |sv| %>
                  <span class="badge badge-ghost"><%= sv.val %></span>
                <% end %>
              </div>
            <% end %>
          </div>
        </section>
      <% end %>

      <footer class="text-xs text-base-content/50 pt-2 border-t border-base-300">
        Last updated <%= time_ago_in_words(@announcement.updated_at) %> ago.
      </footer>
    </div>
  </article>
</div>
