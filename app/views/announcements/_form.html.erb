<div class="app-card">
  <%= form_with(model: announcement) do |form| %>
    <% if announcement.errors.any? %>
      <div class="alert alert-error mb-6">
        <div class="flex items-start">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-2 stroke-current shrink-0" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <div>
            <h4 class="font-medium"><%= pluralize(announcement.errors.count, "error") %> prevented saving:</h4>
            <ul class="list-disc ml-5 mt-2">
              <% announcement.errors.each do |error| %>
                <li class="text-sm"><%= error.full_message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    <% end %>

    <div class="space-y-5">
      <div class="form-control w-full">
        <%= form.label :title, class: "label" %>
        <%= form.text_field :title, class: "input input-bordered w-full" %>
      </div>

      <div class="form-control w-full">
        <%= form.label :preview, class: "label" %>
        <%= form.textarea :preview, class: "textarea textarea-bordered w-full", rows: 2 %>
      </div>

      <div class="form-control w-full">
        <%= form.label :content, class: "label" %>
        <%= form.rich_text_area :content %>
      </div>

      <fieldset class="app-fieldset">
        <legend class="px-2 text-sm font-semibold text-base-content/70">Targeting</legend>
        <p class="text-sm text-base-content/60">For each segment where you select values, a contact must match at least one of those values to see this announcement. Segments with nothing selected do not affect visibility.</p>

        <% Segment.includes(:segment_values).find_each do |segment| %>
          <% values = segment.segment_values.to_a %>
          <% any_selected = values.any? { |v| announcement.segment_value_ids.include?(v.id) } %>
          <details class="app-panel group shadow-none"
                   data-controller="segment-picker"
                   <%= "open" if any_selected %>>
            <summary class="cursor-pointer list-none px-4 py-3 flex items-center justify-between gap-3 select-none">
              <span class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-open:rotate-90" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
                <span class="font-semibold"><%= segment.identifier %></span>
              </span>
              <span class="badge badge-ghost" data-segment-picker-target="count">0 / <%= values.size %></span>
            </summary>
            <div class="px-4 pb-4 pt-1 border-t border-base-200">
              <% if values.size > 8 %>
                <input type="search" placeholder="Filter values…"
                       class="input input-bordered input-sm w-full mb-3"
                       data-segment-picker-target="filter"
                       data-action="input->segment-picker#filter">
              <% end %>
              <div class="flex flex-wrap gap-2">
                <% values.each do |segment_value| %>
                  <label data-segment-picker-target="value"
                         class="cursor-pointer label justify-start gap-2 rounded-box border border-base-200 px-2 py-1">
                    <%= check_box_tag "announcement[segment_value_ids][]",
                          segment_value.id,
                          announcement.segment_value_ids.include?(segment_value.id),
                          id: "segment_value_#{segment_value.id}",
                          data: {segment_picker_target: "checkbox", action: "change->segment-picker#update"} %>
                    <span class="label-text"><%= segment_value.val %></span>
                  </label>
                <% end %>
              </div>
              <div class="mt-3 flex gap-2 text-sm">
                <button type="button" class="link link-primary"
                        data-action="click->segment-picker#toggleAll" data-to-all="select">Select all</button>
                <button type="button" class="link link-hover"
                        data-action="click->segment-picker#toggleAll" data-to-all="clear">Clear</button>
              </div>
            </div>
          </details>
        <% end %>
      </fieldset>

      <div class="mt-8 flex justify-end gap-2">
        <%= link_to "Cancel", announcement.persisted? ? @announcement : announcements_path, class: "btn btn-ghost" %>
        <%= form.submit class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>
</div>
