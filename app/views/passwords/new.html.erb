<div class="min-h-[60vh] grid place-items-center w-full px-4">
  <div class="card bg-base-100 shadow-md w-full max-w-md border border-base-300">
    <div class="card-body space-y-4">
      <%= render "shared/flash" %>
      <h1 class="card-title text-2xl">Forgot your password?</h1>
      <p class="text-sm text-base-content/60">Enter your email and we'll send reset instructions.</p>

      <%= form_with url: passwords_path, class: "space-y-3" do |form| %>
        <div class="form-control">
          <%= form.label :email_address, class: "label label-text" %>
          <%= form.email_field :email_address, required: true, autofocus: true,
            autocomplete: "username", value: params[:email_address],
            class: "input input-bordered input-sm w-full" %>
        </div>
        <div class="flex items-center justify-between">
          <%= form.submit "Email reset instructions", class: "btn btn-primary" %>
          <%= link_to "Back to sign in", new_session_path, class: "link link-hover text-sm" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
