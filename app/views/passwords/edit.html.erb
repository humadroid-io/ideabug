<div class="min-h-[60vh] grid place-items-center w-full px-4">
  <div class="card bg-base-100 shadow-md w-full max-w-md border border-base-300">
    <div class="card-body space-y-4">
      <%= render "shared/flash" %>
      <h1 class="card-title text-2xl">Update your password</h1>

      <%= form_with url: password_path(params[:token]), method: :put, class: "space-y-3" do |form| %>
        <div class="form-control">
          <%= form.label :password, "New password", class: "label label-text" %>
          <%= form.password_field :password, required: true, autocomplete: "new-password",
            maxlength: 72, class: "input input-bordered input-sm w-full" %>
        </div>
        <div class="form-control">
          <%= form.label :password_confirmation, "Repeat new password", class: "label label-text" %>
          <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password",
            maxlength: 72, class: "input input-bordered input-sm w-full" %>
        </div>
        <div class="flex items-center justify-end">
          <%= form.submit "Save", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
