<% reads_count = @contact.announcement_reads.count %>
<% votes_count = @contact.ticket_votes.count %>
<% submissions_count = @contact.submitted_tickets.count %>
<% identity = @contact.identified? ? @contact.external_id : @contact.anonymous_id %>

<div class="app-page space-y-6 py-4">
  <%= section_header \
        title: identity,
        eyebrow: "Audience",
        title_class: "font-mono break-all !text-xl sm:!text-2xl",
        meta_items: [
          (@contact.identified? ? "identified" : "anonymous"),
          "first seen #{time_ago_in_words(@contact.created_at)} ago",
          (@contact.last_seen_at ? "last seen #{time_ago_in_words(@contact.last_seen_at)} ago" : nil),
          (@contact.announcements_opted_out? ? "announcements opt-out" : nil)
        ] do %>
    <div class="flex gap-2">
      <%= link_to "Back", contacts_path, class: "btn btn-sm btn-ghost" %>
      <%= link_to "Delete", @contact,
            class: "btn btn-sm btn-ghost text-error",
            data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %>
    </div>
  <% end %>

  <article class="app-card">
    <div class="card-body space-y-6">
      <section class="stats stats-horizontal w-full rounded-box bg-base-200/40 shadow-sm">
        <div class="stat py-2">
          <div class="stat-title text-xs">Reads</div>
          <div class="stat-value text-xl"><%= reads_count %></div>
        </div>
        <div class="stat py-2">
          <div class="stat-title text-xs">Votes</div>
          <div class="stat-value text-xl"><%= votes_count %></div>
        </div>
        <div class="stat py-2">
          <div class="stat-title text-xs">Submissions</div>
          <div class="stat-value text-xl"><%= submissions_count %></div>
        </div>
      </section>

      <section class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="app-subpanel">
          <h2 class="text-xs uppercase tracking-wide text-base-content/60 font-semibold mb-3">Identity</h2>
          <dl class="space-y-2 text-sm">
            <div class="flex justify-between gap-4">
              <dt class="text-base-content/60">External ID</dt>
              <dd class="font-mono text-xs break-all">
                <%= @contact.external_id || content_tag(:span, "—", class: "text-base-content/40") %>
              </dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-base-content/60">Anonymous ID</dt>
              <dd class="font-mono text-xs break-all">
                <%= @contact.anonymous_id || content_tag(:span, "—", class: "text-base-content/40") %>
              </dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-base-content/60">Database ID</dt>
              <dd class="font-mono text-xs">#<%= @contact.id %></dd>
            </div>
          </dl>
        </div>

        <div class="app-subpanel">
          <h2 class="text-xs uppercase tracking-wide text-base-content/60 font-semibold mb-3">Info payload</h2>
          <% if @contact.info_payload.present? %>
            <dl class="space-y-1 text-sm">
              <% @contact.info_payload.each do |key, value| %>
                <div class="flex gap-2">
                  <dt class="text-base-content/60 min-w-24 shrink-0"><%= key.to_s.humanize %></dt>
                  <dd class="break-all"><%= value %></dd>
                </div>
              <% end %>
            </dl>
          <% else %>
            <p class="text-sm text-base-content/50 italic">No metadata received.</p>
          <% end %>
        </div>
      </section>

      <section>
        <h2 class="text-xs uppercase tracking-wide text-base-content/60 font-semibold mb-3">Segments</h2>
        <% if @contact.segments.any? %>
          <div class="space-y-2">
            <% @contact.segments.each do |segment| %>
              <% values = @contact.segment_values.where(segment: segment) %>
              <div class="flex flex-wrap items-center gap-2">
                <span class="font-medium text-sm min-w-24"><%= segment.identifier %></span>
                <% values.each do |sv| %>
                  <span class="badge badge-ghost"><%= sv.val %></span>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-base-content/50 italic">No segment values assigned.</p>
        <% end %>
      </section>

      <% if @contact.segments_payload.present? && @contact.segments_payload.any? %>
        <section>
          <h2 class="text-xs uppercase tracking-wide text-base-content/60 font-semibold mb-2">Last segments_payload (raw, from JWT)</h2>
          <pre class="app-subpanel overflow-x-auto p-3 text-xs"><%= JSON.pretty_generate(@contact.segments_payload) %></pre>
        </section>
      <% end %>
    </div>
  </article>
</div>
