/* vim: set filetype=javascript : */
/* ideabug bootstrap shell */
(function () {
  if (window.__ideabug_loaded) return;
  window.__ideabug_loaded = true;

  var script =
    document.currentScript ||
    (function () {
      var scripts = document.querySelectorAll('script[src*="/script.js"]');
      return scripts[scripts.length - 1];
    })();

  var dataset = (script && script.dataset) || {};
  var host =
    dataset.ideabugHost ||
    (script && script.src ? new URL(script.src).origin : "<%= request.base_url %>");
  var target = dataset.ideabugTarget;

  function inject(tag, attrs) {
    var el = document.createElement(tag);
    Object.keys(attrs).forEach(function (k) {
      el[k] = attrs[k];
    });
    document.head.appendChild(el);
    return el;
  }

  inject("link", {
    rel: "stylesheet",
    href: host + "<%= asset_path('ideabug_widget.css') %>"
  });

  var js = inject("script", {
    src: host + "<%= asset_path('ideabug_widget.js') %>",
    async: true
  });

  js.addEventListener("load", function () {
    if (window.IdeabugWidget && target) {
      window.IdeabugWidget.configure({ apiHost: host, targetElement: target });
    }
    // Fire AFTER apiHost+targetElement are configured so user listeners can
    // safely call IdeabugWidget.configure({ jwt: … }).
    document.dispatchEvent(new CustomEvent("ideabug:ready"));
  });
})();
