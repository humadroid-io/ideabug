<section class="app-card">
  <h2 class="text-sm uppercase tracking-wide text-base-content/60 font-semibold mb-3"><%= title %></h2>
  <% if tickets.empty? %>
    <p class="text-sm text-base-content/40 italic"><%= empty %></p>
  <% else %>
    <ul class="space-y-3">
      <% tickets.each do |t| %>
        <li class="app-subpanel p-3">
          <div class="flex items-start justify-between gap-2">
            <%= link_to t.title, edit_ticket_path(t), class: "font-medium link link-hover" %>
            <% if t.feature_request? %><span class="badge badge-ghost badge-sm shrink-0"><%= t.votes_count %></span><% end %>
          </div>
          <div class="text-xs text-base-content/60 mt-1 flex flex-wrap items-center gap-2">
            <%= classification_pill(t) %>
            <% if t.scheduled_for %><span>scheduled <%= l(t.scheduled_for.to_date, format: :default) %></span><% end %>
            <% if t.shipped_at %><span>shipped <%= time_ago_in_words(t.shipped_at) %> ago</span><% end %>
          </div>
          <div class="mt-2 flex flex-wrap gap-1">
            <% unless t.in_progress_status? %>
              <%= button_to "Start", transition_ticket_path(t, to: "start"), method: :post, class: "btn btn-xs btn-ghost" %>
            <% end %>
            <% unless t.shipped_at %>
              <%= button_to "Mark shipped", transition_ticket_path(t, to: "ship"), method: :post, class: "btn btn-xs btn-primary btn-outline" %>
            <% end %>
            <% if t.shipped_at %>
              <%= button_to "Reopen", transition_ticket_path(t, to: "reopen"), method: :post, class: "btn btn-xs btn-ghost" %>
            <% end %>
            <% if t.scheduled_for && t.shipped_at.nil? %>
              <%= button_to "Unschedule", transition_ticket_path(t, to: "unschedule"), method: :post, class: "btn btn-xs btn-ghost" %>
            <% end %>
          </div>
        </li>
      <% end %>
    </ul>
  <% end %>
</section>
