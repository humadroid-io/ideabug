<div class="w-full max-w-4xl mx-auto p-4 space-y-6">
  <header class="flex items-start justify-between gap-4 flex-wrap">
    <div class="text-sm text-base-content/60">
      <%= link_to "Tickets", tickets_path, class: "link link-hover" %>
      <span class="mx-1">›</span>
      <span>#<%= @ticket.id %></span>
    </div>
    <div class="flex gap-2">
      <%= link_to "Back", tickets_path, class: "btn btn-sm btn-ghost" %>
      <%= link_to "Edit", edit_ticket_path(@ticket), class: "btn btn-sm" %>
      <%= link_to "Delete", @ticket,
            class: "btn btn-sm btn-ghost text-error",
            data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %>
    </div>
  </header>

  <%= render @ticket %>
</div>
