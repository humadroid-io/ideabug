<div class="app-page space-y-4 py-4">
  <%= section_header \
        title: "Tickets",
        eyebrow: "Feedback",
        meta_items: [
          pluralize(@pagy&.count || @tickets.size, "ticket"),
          "bugs, features, tasks"
        ] do %>
    <div class="flex gap-2">
      <%= link_to "Roadmap", timeline_tickets_path, class: "btn btn-ghost btn-sm" %>
      <%= link_to "New ticket", new_ticket_path, class: "btn btn-primary btn-sm" %>
    </div>
  <% end %>

  <%= form_with url: tickets_path, method: :get, class: "flex flex-wrap items-end gap-2", local: true do %>
    <div class="form-control">
      <label class="label label-text" for="q">Search</label>
      <input
        id="q"
        type="text"
        name="q"
        value="<%= params[:q] %>"
        placeholder="Title or description"
        class="input input-bordered input-sm w-64"
      >
    </div>
    <div class="form-control">
      <label class="label label-text" for="classification">Classification</label>
      <select
        id="classification"
        name="classification"
        class="select select-bordered select-sm py-0"
      >
        <option value="">All</option>
        <% Ticket.classifications.keys.each do |cls| %>
          <option value="<%= cls %>" <%= "selected" if params[:classification] == cls %>><%= cls.titleize %></option>
        <% end %>
      </select>
    </div>
    <div class="form-control">
      <label class="label label-text" for="status">Status</label>
      <select id="status" name="status" class="select select-bordered select-sm py-0">
        <option value="">All</option>
        <% Ticket.statuses.keys.each do |st| %>
          <option value="<%= st %>" <%= "selected" if params[:status] == st %>><%= st.titleize %></option>
        <% end %>
      </select>
    </div>
    <div class="form-control">
      <label class="label label-text" for="sort">Sort</label>
      <select id="sort" name="sort" class="select select-bordered select-sm py-0">
        <option value="">Newest</option>
        <option value="votes" <%= "selected" if params[:sort] == "votes" %>>Most voted</option>
      </select>
    </div>
    <button type="submit" class="btn btn-sm btn-primary">Apply</button>
    <%= if params.values_at(:q, :classification, :status, :sort).any?(&:present?)
      link_to "Reset", tickets_path, class: "btn btn-sm btn-ghost"
    end %>
  <% end %>

  <% if @tickets.empty? %>
    <div class="app-empty-state">
      No tickets match your filters.
    </div>
  <% else %>
    <div class="app-panel overflow-x-auto overflow-hidden">
      <table class="table table-sm">
        <thead class="bg-base-200">
          <tr>
            <th>Title</th>
            <th>Classification</th>
            <th>Status</th>
            <th class="text-right">Votes</th>
            <th>Scheduled</th>
            <th>Source</th>
            <th>Created</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @tickets.each do |ticket| %>
            <tr>
              <td class="font-medium"><%= link_to ticket.title, ticket_path(ticket), class: "link link-hover" %></td>
              <td><%= classification_pill(ticket) %></td>
              <td><span class="badge badge-ghost"><%= ticket.status.titleize %></span></td>
              <td class="text-right"><%= ticket.votes_count %></td>
              <td><%= l(ticket.scheduled_for.to_date, format: :default) if ticket.scheduled_for %></td>
              <td><span class="text-xs text-base-content/60"><%= ticket.source %></span></td>
              <td class="text-xs text-base-content/60" title="<%= ticket.created_at %>"><%= time_ago_in_words(ticket.created_at) %>
                ago</td>
              <td><%= link_to "Edit", edit_ticket_path(ticket), class: "link link-primary text-xs" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="flex justify-center"><%== pagy_nav(@pagy) %></div>
  <% end %>
</div>
