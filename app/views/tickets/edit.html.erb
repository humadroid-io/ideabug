<div class="app-page space-y-6 py-4">
  <%= section_header \
        title: "Edit ticket",
        eyebrow: "Feedback",
        meta_items: ["ticket ##{@ticket.id}", @ticket.title] do %>
    <%= link_to "Back", @ticket, class: "btn btn-ghost btn-sm" %>
  <% end %>

  <%= render "form", ticket: @ticket %>
</div>
