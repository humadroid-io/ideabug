<div class="w-full max-w-7xl mx-auto p-4 space-y-6">
  <header class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold">Roadmap timeline</h1>
      <p class="text-sm text-base-content/60">Drag-free editor — set scheduled or shipped from each ticket's edit page.</p>
    </div>
    <%= link_to "All tickets", tickets_path, class: "btn btn-sm btn-ghost" %>
  </header>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <%= render "lane", title: "Now", tickets: @now, empty: "Nothing in flight." %>
    <%= render "lane", title: "Next", tickets: @next, empty: "No scheduled work yet." %>
    <%= render "lane", title: "Shipped", tickets: @shipped, empty: "Nothing shipped recently." %>
  </div>

  <% if @backlog.any? %>
    <section>
      <h2 class="font-semibold mb-2">Top requested ideas (not yet scheduled)</h2>
      <ul class="space-y-2">
        <% @backlog.each do |t| %>
          <li class="flex items-center justify-between bg-base-100 border border-base-300 rounded-lg p-3">
            <%= link_to t.title, edit_ticket_path(t), class: "link link-hover font-medium" %>
            <span class="badge badge-ghost"><%= t.votes_count %> votes</span>
          </li>
        <% end %>
      </ul>
    </section>
  <% end %>
</div>
