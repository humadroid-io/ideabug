<% content_for :title, "Roadmap" %>
<% content_for :head do %>
  <link rel="canonical" href="<%= request.base_url %>/roadmap">
  <meta property="og:title" content="Roadmap">
  <meta property="og:type" content="website">
  <meta property="og:url" content="<%= request.base_url %>/roadmap">
<% end %>

<% selected_tab = params[:tab].presence_in(%w[next now shipped]) || "next" %>
<% tab_counts = {
  "next" => @buckets[:next].size,
  "now" => @buckets[:now].size,
  "shipped" => @buckets[:shipped].size
} %>

<section class="public-page py-6 sm:py-8">
  <header class="border-b border-base-300 pb-3">
    <div>
      <p class="public-eyebrow">Public roadmap</p>
      <h1 class="public-title mt-2">Roadmap</h1>
    </div>

    <div class="mt-2 flex flex-wrap gap-x-3 gap-y-1">
      <span class="public-meta-chip"><%= pluralize(@buckets[:next].size, "next item") %></span>
      <span class="public-meta-chip"><%= pluralize(@buckets[:ideas].size, "feature request") %></span>
      <span class="public-meta-chip"><%= pluralize(@buckets[:shipped].size, "shipped item") %></span>
    </div>
  </header>

  <div class="mt-3 flex flex-col gap-3">
    <nav class="tabs tabs-bordered">
      <% [["next", "Next"], ["now", "In progress"], ["shipped", "Shipped"]].each do |key, label| %>
        <% active = selected_tab == key %>
        <%= link_to roadmap_path(tab: key),
              class: "tab tab-sm gap-2 px-0 #{active ? 'tab-active font-medium text-primary' : 'text-base-content/60'}" do %>
          <span><%= label %></span>
          <span class="badge badge-sm <%= active ? 'badge-primary badge-outline' : 'badge-ghost' %>"><%= tab_counts[key] %></span>
        <% end %>
      <% end %>
    </nav>

    <% if selected_tab == "next" %>
      <%= render "lane",
            title: "Next",
            tickets: @buckets[:next],
            date_field: :scheduled_for,
            date_label: "Target",
            empty_state: "Nothing scheduled yet." %>

      <section class="public-panel overflow-hidden">
        <div class="flex items-center justify-between border-b border-base-300 px-4 py-3 sm:px-5">
          <h2 class="text-base font-semibold tracking-tight text-base-content">Feature requests</h2>
          <span class="text-sm text-base-content/50"><%= pluralize(@buckets[:ideas].size, "item") %></span>
        </div>

        <div>
          <% if @buckets[:ideas].empty? %>
            <div class="px-4 py-8 text-center text-sm text-base-content/50 sm:px-5">
              No feature requests are open for votes right now.
            </div>
          <% else %>
            <ol class="public-list">
              <% @buckets[:ideas].each_with_index do |ticket, index| %>
                <li id="ticket-<%= ticket.id %>" class="public-list-row">
                  <div class="grid min-w-0 grid-cols-[auto_minmax(0,1fr)] items-start gap-4">
                    <span class="text-xs font-semibold tabular-nums text-primary/70"><%= format("%02d", index + 1) %></span>
                    <div class="min-w-0">
                      <h3 class="text-sm font-semibold leading-5 text-base-content sm:text-base">
                        <%= link_to ticket.title, public_feature_path(ticket), class: "transition hover:opacity-80" %>
                      </h3>
                    </div>
                  </div>

                  <div class="text-right">
                    <div class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-primary/70">Votes</div>
                    <div class="mt-0.5 text-lg font-semibold tabular-nums text-primary"><%= ticket.votes_count %></div>
                  </div>
                </li>
              <% end %>
            </ol>
          <% end %>
        </div>
      </section>
    <% elsif selected_tab == "now" %>
      <%= render "lane",
            title: "In progress",
            tickets: @buckets[:now],
            date_field: nil,
            date_label: nil,
            empty_state: "Nothing is currently marked as in progress." %>
    <% else %>
      <%= render "lane",
            title: "Shipped",
            tickets: @buckets[:shipped],
            date_field: :shipped_at,
            date_label: "Shipped",
            empty_state: "Nothing shipped yet." %>
    <% end %>
  </div>
</section>
