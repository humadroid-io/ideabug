<% content_for :title, @announcement.title %>
<% content_for :head do %>
  <link rel="canonical" href="<%= request.base_url %>/changelog/<%= @announcement.id %>">
  <meta property="og:title" content="<%= @announcement.title %>">
  <meta property="og:type" content="article">
  <meta property="og:url" content="<%= request.base_url %>/changelog/<%= @announcement.id %>">
  <% if @announcement.preview.present? %>
    <meta property="og:description" content="<%= @announcement.preview %>">
    <meta name="description" content="<%= @announcement.preview %>">
  <% end %>
  <meta property="article:published_time" content="<%= @announcement.published_at.iso8601 %>">
<% end %>

<section class="public-page py-6 sm:py-8">
  <div>
    <nav class="mb-5">
      <%= link_to public_announcements_path,
            class: "link link-primary no-underline hover:no-underline text-sm font-medium inline-flex items-center gap-1.5" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
        Back to changelog
      <% end %>
    </nav>

    <article>
      <header class="border-b border-base-300 pb-5">
        <div class="flex flex-wrap items-center gap-3">
          <span class="public-meta-chip">
            <time datetime="<%= @announcement.published_at.iso8601 %>"><%= l(@announcement.published_at.to_date, format: :long) %></time>
          </span>
        </div>

        <h1 class="mt-3 text-2xl font-semibold leading-tight tracking-tight text-base-content sm:text-3xl"><%= @announcement.title %></h1>
        <% if @announcement.preview.present? %>
          <p class="mt-2.5 text-sm leading-6 text-base-content/70 sm:text-base"><%= @announcement.preview %></p>
        <% end %>
      </header>

      <div class="pt-5">
        <div class="public-prose">
          <%= @announcement.content %>
        </div>
      </div>
    </article>
  </div>
</section>
