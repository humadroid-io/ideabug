<div class="app-page space-y-8 py-4">
  <%= section_header \
        title: "Dashboard",
        eyebrow: "Overview",
        meta_items: [
          pluralize(@stats[:contacts_total], "contact"),
          pluralize(@stats[:announcements_total], "announcement"),
          "#{@stats[:votes_last_7d]} votes in 7d"
        ] %>

  <section class="stats stats-vertical w-full rounded-box border border-base-300 bg-base-100 shadow-sm lg:stats-horizontal">
    <div class="stat">
      <div class="stat-title">Contacts</div>
      <div class="stat-value text-2xl"><%= @stats[:contacts_total] %></div>
      <div class="stat-desc"><%= @stats[:contacts_identified] %> identified · <%= @stats[:contacts_anonymous] %> anonymous</div>
    </div>
    <div class="stat">
      <div class="stat-title">Active (24h)</div>
      <div class="stat-value text-2xl"><%= @stats[:contacts_active_24h] %></div>
    </div>
    <div class="stat">
      <div class="stat-title">Announcements</div>
      <div class="stat-value text-2xl"><%= @stats[:announcements_total] %></div>
      <div class="stat-desc"><%= @stats[:announcements_last_30d] %> in last 30d</div>
    </div>
    <div class="stat">
      <div class="stat-title">Reads (7d)</div>
      <div class="stat-value text-2xl"><%= @stats[:reads_last_7d] %></div>
    </div>
    <div class="stat">
      <div class="stat-title">Votes (7d)</div>
      <div class="stat-value text-2xl"><%= @stats[:votes_last_7d] %></div>
    </div>
  </section>

  <% if @reads_by_week.any? %>
    <section class="app-card">
      <h2 class="font-semibold mb-2">Announcement reads — last 8 weeks</h2>
      <%= sparkline_svg(@reads_by_week.map { |_, v| v }) %>
    </section>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <section class="app-card">
      <h2 class="font-semibold mb-3">Top requested features</h2>
      <% if @top_features.empty? %>
        <p class="text-sm text-base-content/60">No active feature requests yet.</p>
      <% else %>
        <ul class="space-y-2">
          <% @top_features.each do |t| %>
            <li class="flex items-center justify-between gap-2">
              <%= link_to t.title, ticket_path(t), class: "link link-hover" %>
              <span class="badge badge-ghost"><%= t.votes_count %></span>
            </li>
          <% end %>
        </ul>
      <% end %>
    </section>

    <section class="app-card">
      <h2 class="font-semibold mb-3">Recent bugs</h2>
      <% if @recent_bugs.empty? %>
        <p class="text-sm text-base-content/60">No bug reports.</p>
      <% else %>
        <ul class="space-y-2">
          <% @recent_bugs.each do |t| %>
            <li class="flex items-center justify-between gap-2">
              <%= link_to t.title, ticket_path(t), class: "link link-hover" %>
              <span class="text-xs text-base-content/60"><%= time_ago_in_words(t.created_at) %> ago</span>
            </li>
          <% end %>
        </ul>
      <% end %>
    </section>
  </div>
</div>
